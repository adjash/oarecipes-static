---
const { instructions } = Astro.props;

const { Content } = await instructions.render();
---

<section
  class="lg:col-span-3 bg-white border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]"
>
  <h2 class="mb-6 text-3xl font-black uppercase italic">Instructions</h2>

  <div
    class="prose prose-xl max-w-none prose-strong:font-black prose-p:font-medium [&_ol]:list-decimal [&_li]:mb-2 text-xl"
  >
    <Content />
  </div>
</section>
