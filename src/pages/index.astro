---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import RecipeCard from "../components/recipes/RecipeCard.astro";

const recipes = await getCollection("recipes");
const shuffle = (arr: any) => [...arr].sort(() => Math.random() - 0.5);
const shuffled = shuffle(recipes)
  .filter((r) => r.data)
  .slice(0, 3);
---

<Layout>
  <div class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="mb-12 text-5xl font-black uppercase italic tracking-tighter">
      Most recent recipes
    </h1>
    <ul class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {shuffled.map((recipe) => <RecipeCard recipe={recipe} />)}
    </ul>
  </div>
</Layout>
