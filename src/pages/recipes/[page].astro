---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import RecipeCard from "../../components/recipes/RecipeCard.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const recipes = await getCollection("recipes");
  return paginate(recipes, { pageSize: 3 });
}

const { page } = Astro.props;
---

<Layout>
  <div class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="mb-12 text-6xl font-black uppercase italic tracking-tighter">
      Recipes
    </h1>

    <ul class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {page.data.map((recipe: any) => <RecipeCard recipe={recipe} />)}
    </ul>

    <nav
      class="mt-20 flex items-center justify-between border-t-8 border-black pt-8"
    >
      {
        page.url.prev ? (
          <a
            href={page.url.prev}
            class="border-4 border-black bg-white px-6 py-2 text-lg font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all"
          >
            ← Back
          </a>
        ) : (
          <span />
        )
      }

      <p
        class="text-xl font-black uppercase bg-yellow-300 border-2 border-black px-4 py-1"
      >
        {page.currentPage} / {page.lastPage}
      </p>

      {
        page.url.next ? (
          <a
            href={page.url.next}
            class="border-4 border-black bg-white px-6 py-2 text-lg font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all"
          >
            Next →
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</Layout>
