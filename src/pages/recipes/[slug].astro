---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();
---

<Layout>
  <article class="mx-auto w-[95%] max-w-7xl px-4 py-12">
    <section class="mb-12">
      <h1
        class="mb-4 text-6xl font-black uppercase tracking-tighter leading-none"
      >
        {recipe.data.title}
      </h1>

      <p class="mb-6 text-xl font-medium border-l-8 border-black pl-4">
        {recipe.data.description}
      </p>

      <div class="flex flex-wrap items-center gap-6 mb-8">
        <a
          href="#recipe"
          class="px-6 py-3 border-4 border-black bg-orange-500 text-white font-black text-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all"
        >
          JUMP TO RECIPE
        </a>

        <div
          class="font-bold uppercase bg-white border-2 border-black p-2 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
        >
          Prep: {recipe.data.prepTime}m · Cook: {recipe.data.cookTime}m ·
          Serves: {recipe.data.servings}
        </div>
      </div>

      <div
        class="border-4 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] inline-block w-full"
      >
        <Image
          src={recipe.data.image}
          alt={recipe.data.title}
          class="w-full h-auto object-cover max-h-[500px]"
        />
      </div>
    </section>

    <div class="grid gap-12 lg:grid-cols-5">
      <section
        class="lg:col-span-2 bg-cyan-200 border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]"
      >
        <span class="block relative -top-24" id="recipe"></span>
        <h2
          class="mb-6 text-3xl font-black uppercase italic border-b-4 border-black pb-2"
        >
          Ingredients
        </h2>

        <ul class="space-y-4">
          {
            recipe.data.ingredients.map((ingredient) => (
              <li class="grid grid-cols-3 text-lg font-bold">
                <span class="col-span-1 underline decoration-4">
                  {ingredient.amount} {ingredient.unit}
                </span>
                <span class="col-span-2 uppercase">
                  {ingredient.name} {ingredient.format}
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      <section
        class="lg:col-span-3 bg-white border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]"
      >
        <h2 class="mb-6 text-3xl font-black uppercase italic">Instructions</h2>

        <div
          class="prose prose-xl max-w-none prose-strong:font-black prose-p:font-medium [&_ol]:list-decimal [&_li]:mb-2 text-xl"
        >
          <Content />
        </div>
      </section>
    </div>

    <aside
      class="mt-16 border-4 border-black bg-lime-300 p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]"
    >
      <h2 class="mb-4 text-2xl font-black uppercase tracking-tight">Notes</h2>
      <div class="text-xl font-bold leading-relaxed">
        {recipe.data.notes}
      </div>
    </aside>
  </article>
</Layout>
